// 2. KERNEL INITIALIZATION
window.DREAM = {
    state: { activeModule: 'home', isGhostMode: false },
    
    // SAFE MODULE LOADER (Mencegah error 'not loaded')
    async load(key) {
        console.log(`[DREAM] 🚀 Initializing Bridge to: ${key}`);
        this.haptic(40);

        if (key === 'home') {
            location.reload(); // Refresh untuk kembali ke dashboard utama secara bersih
            return;
        }

        const mod = MODULES[key];
        if (!mod) return console.error(`[ERROR] Module ${key} not registered.`);

        try {
            // Hot-fix: Pastikan path benar dan file ada di GitHub
            const moduleInstance = await import(mod.path);
            if (moduleInstance && moduleInstance.init) {
                document.body.innerHTML = `<div id="module-container"></div>`; 
                moduleInstance.init('module-container');
                this.state.activeModule = key;
                console.log(`[DREAM INFO] ${mod.label} Synced ✅`);
            }
        } catch (err) {
            console.error(`[CRITICAL] Failure loading ${key}:`, err);
            alert(`⚠️ Sovereign Alert: Gagal memuat modul ${mod.label}. Periksa path: ${mod.path}`);
        }
    },

    haptic(ms) { if ('vibrate' in navigator) navigator.vibrate(ms); }
};

// 3. GHOST DEVELOPER ROOM (ERUDA-STYLE)
const GhostConsole = {
    logs: [],
    init() {
        if (document.getElementById('ghost-terminal')) return;
        
        const el = document.createElement('div');
        el.id = 'ghost-terminal';
        el.style.cssText = `
            position: fixed; bottom: 0; left: 0; width: 100%; height: 60vh;
            background: rgba(2, 6, 23, 0.95); border-top: 2px solid #10b981;
            z-index: 10000; font-family: monospace; display: flex; flex-direction: column;
            box-shadow: 0 -20px 50px rgba(0,0,0,0.8); backdrop-filter: blur(15px);
            animation: slideUp 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        `;
        
        el.innerHTML = `
            <div style="background:#0f172a; padding:10px; display:flex; justify-content:space-between; border-bottom:1px solid #10b981;">
                <span style="color:#10b981; font-weight:bold; font-size:12px;">GHOST_ARCHITECT_CONSOLE v13.0</span>
                <button onclick="this.parentElement.parentElement.remove()" style="background:none; border:none; color:white; font-size:18px;">×</button>
            </div>
            <div id="ghost-log-stream" style="flex:1; overflow-y:auto; padding:15px; color:#34d399; font-size:11px; line-height:1.6;">
                <div>[SYS] Sovereign Kernel Active...</div>
                <div>[SYS] Checking ISO 27001 Compliance... OK</div>
            </div>
            <div style="background:#020617; padding:10px; border-top:1px solid #10b981;">
                <input type="text" id="ghost-input" placeholder="Enter Kernel Command..." 
                       style="width:100%; background:none; border:none; color:white; outline:none; font-family:monospace;">
            </div>
        `;
        document.body.appendChild(el);
        this.interceptLogs();
        this.setupCommands();
    },

    interceptLogs() {
        const stream = document.getElementById('ghost-log-stream');
        const oldLog = console.log;
        console.log = (...args) => {
            const line = document.createElement('div');
            line.style.marginBottom = '4px';
            line.innerHTML = `<span style="color:#64748b;">[${new Date().toLocaleTimeString()}]</span> ${args.join(' ')}`;
            stream.appendChild(line);
            stream.scrollTop = stream.scrollHeight;
            oldLog.apply(console, args);
        };
    },

    setupCommands() {
        const input = document.getElementById('ghost-input');
        input.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                const cmd = input.value.toLowerCase();
                console.log(`> ${cmd}`);
                if (cmd === 'clear') document.getElementById('ghost-log-stream').innerHTML = '';
                if (cmd === 'reboot') location.reload();
                if (cmd === 'modules') console.log('Available Modules:', Object.keys(MODULES));
                input.value = '';
            }
        });
    }
};

// 4. TRIGGER SYSTEM (5-TAP)
function setupStealthTrigger() {
    let taps = 0;
    let timeout;
    const zone = document.getElementById('ghost-trigger-zone');
    
    if (!zone) return;

    zone.addEventListener('click', () => {
        taps++;
        window.DREAM.haptic(30);
        if (timeout) clearTimeout(timeout);
        
        if (taps === 5) {
            taps = 0;
            const code = prompt('🔑 GHOST ACCESS CODE:');
            if (code === 'dreamos2026') {
                window.DREAM.haptic([100, 50, 100]);
                GhostConsole.init();
            } else {
                alert('❌ Unauthorized Architect.');
            }
        }
        timeout = setTimeout(() => taps = 0, 2000);
    });
}

